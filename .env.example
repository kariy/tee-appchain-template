# .env.example — SECRETS for running scripts/deploy.sh, scripts/init.sh, and
# scripts/deploy-monitoring.sh locally. Copy to .env (gitignored) and `source .env`,
# or export the vars directly. Real gas + secrets — never commit .env.
#
# Everything NON-SECRET (chain name/ids, domains, ports, registries, version pins)
# lives in appchain.conf — edit that instead. When deploying via the GitHub workflows,
# these values come from GitHub secrets (see SETUP.md), not this file.

# Settlement accounts ("saya"), one per network: deploy piltover at init, and are the sole
# update_state callers at runtime (embedded settlement — INSIDE the enclave for MODE=enclave).
# Must be deployed + funded on their network (STRK for update_state gas). The scripts pick
# the pair matching NETWORK; unsuffixed SETTLEMENT_ADDRESS / SETTLEMENT_PRIVATE_KEY override.
SETTLEMENT_ADDRESS_SEPOLIA=""
SETTLEMENT_PRIVATE_KEY_SEPOLIA=""
SETTLEMENT_ADDRESS_MAINNET=""
SETTLEMENT_PRIVATE_KEY_MAINNET=""

# SP1 prover network (Succinct) key — real Groth16 proving (enclave mode). Absent ⇒ the
# enclave runs TeeProver::Mock (no real proofs); ignored in MODE=mock. See TEE.md.
PROVER_KEY=""

# --- Monitoring (scripts/deploy-monitoring.sh → host/monitoring docker-compose) ---
# Slack incoming-webhook for Grafana alerts (empty ⇒ alerts fire in Grafana only, no Slack).
SLACK_WEBHOOK_URL=""
# Grafana admin password (set one — defaults to 'admin' if empty).
GRAFANA_ADMIN_PASSWORD=""
# Succinct prover-network accounts (public addresses) to alert on when their $PROVE balance
# runs low, as a `network=address[=deployment]` comma list. Empty ⇒ no balance alert.
SUCCINCT_PROVER_ACCOUNTS=""
# Settlement (saya) accounts (public addresses) to watch for low STRK, same format.
STARKNET_SETTLEMENT_ACCOUNTS=""
