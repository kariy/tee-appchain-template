{
 "uid": "appchain-overview",
 "title": "Appchain Overview",
 "tags": [
  "appchain"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 5,
 "refresh": "30s",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "templating": {
  "list": [
   {
    "name": "deployment",
    "label": "Deployment",
    "type": "query",
    "datasource": {
     "type": "loki",
     "uid": "loki"
    },
    "query": "label_values({job=\"systemd-journal\"}, deployment)",
    "definition": "label_values({job=\"systemd-journal\"}, deployment)",
    "refresh": 1,
    "sort": 1,
    "multi": true,
    "includeAll": true,
    "current": {
     "selected": true,
     "text": [
      "All"
     ],
     "value": [
      "$__all"
     ]
    }
   }
  ]
 },
 "annotations": {
  "list": []
 },
 "panels": [
  {
   "id": 1,
   "type": "stat",
   "title": "RPC up",
   "gridPos": {
    "h": 5,
    "w": 8,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "probe_success{job=\"blackbox-rpc\"}",
     "legendFormat": "{{deployment}}",
     "instant": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "mappings": [
      {
       "type": "value",
       "options": {
        "0": {
         "text": "DOWN",
         "color": "red"
        },
        "1": {
         "text": "UP",
         "color": "green"
        }
       }
      }
     ],
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "background",
    "graphMode": "none",
    "textMode": "value_and_name"
   }
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "RPC latency (probe duration)",
   "gridPos": {
    "h": 5,
    "w": 8,
    "x": 8,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "probe_duration_seconds{job=\"blackbox-rpc\"}",
     "legendFormat": "{{deployment}}"
    }
   ]
  },
  {
   "id": 3,
   "type": "timeseries",
   "title": "Settled block (piltover)",
   "gridPos": {
    "h": 5,
    "w": 8,
    "x": 16,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "katana_settlement_settled_block",
     "legendFormat": "{{deployment}}"
    }
   ]
  },
  {
   "id": 4,
   "type": "timeseries",
   "title": "Host CPU busy %",
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 0,
    "y": 5
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "max": 100
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
     "legendFormat": "cpu busy"
    }
   ]
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Host memory available %",
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 8,
    "y": 5
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "max": 100
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 * node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
     "legendFormat": "mem available"
    }
   ]
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Disk free % (per mount)",
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 16,
    "y": 5
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "max": 100
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 * node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs\"}",
     "legendFormat": "{{mountpoint}}"
    }
   ]
  },
  {
   "id": 8,
   "type": "stat",
   "title": "Succinct prover balance (PROVE)",
   "description": "Succinct prover-network accounts (configured via SUCCINCT_PROVER_ACCOUNTS in the monitoring .env)",
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 0,
    "y": 11
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "decimals": 3,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "yellow",
        "value": 10
       },
       {
        "color": "green",
        "value": 25
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "background",
    "graphMode": "area",
    "textMode": "value_and_name",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": ""
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "succinct_prover_balance_prove",
     "legendFormat": "{{network}}",
     "instant": true
    }
   ]
  },
  {
   "id": 9,
   "type": "timeseries",
   "title": "Succinct prover balance trend (PROVE)",
   "description": "Succinct prover-network accounts (configured via SUCCINCT_PROVER_ACCOUNTS in the monitoring .env)",
   "gridPos": {
    "h": 6,
    "w": 16,
    "x": 8,
    "y": 11
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10,
      "lineWidth": 2,
      "thresholdsStyle": {
       "mode": "line"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 10
       }
      ]
     }
    }
   },
   "options": {
    "legend": {
     "showLegend": true,
     "displayMode": "list",
     "placement": "bottom"
    },
    "tooltip": {
     "mode": "multi"
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "succinct_prover_balance_prove",
     "legendFormat": "{{network}}"
    }
   ]
  },
  {
