  {
   "id": 7,
   "type": "logs",
   "title": "Logs \u2014 $deployment",
   "repeat": "deployment",
   "repeatDirection": "v",
   "gridPos": {
    "h": 9,
    "w": 24,
    "x": 0,
    "y": 23
   },
   "datasource": {
    "type": "loki",
    "uid": "loki"
   },
   "options": {
    "showTime": true,
    "wrapLogMessage": true,
